{
  "name": "@nustackjs/lint-plugin-vueuse",
  "type": "module",
  "version": "0.0.0",
  "description": "VueUse lint rules for the Nustack ecosystem.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@oxlint/plugins": "catalog:"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "peerDependenciesMeta": {
    "eslint": {
      "optional": true
    }
  },
  "devDependencies": {
    "eslint": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "vue-eslint-parser": "catalog:"
  }
}
