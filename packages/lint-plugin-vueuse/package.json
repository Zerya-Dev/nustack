{
  "name": "@nustackjs/lint-plugin-vueuse",
  "type": "module",
  "version": "0.2.0",
  "description": "ESLint and Oxlint rules for VueUse. Used by @nustackjs/lint, usable standalone.",
  "author": "Norbiros <me@norbiros.dev>",
  "license": "MIT",
  "homepage": "https://github.com/Zerya-Dev/nustack/tree/master/packages/lint-plugin-vueuse#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zerya-Dev/nustack.git",
    "directory": "packages/lint-plugin-vueuse"
  },
  "keywords": [
    "eslint",
    "oxlint",
    "eslint-plugin",
    "vueuse",
    "vue",
    "nuxt",
    "nustack",
    "lint"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "tsdown src/index.ts --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9"
  },
  "dependencies": {
    "@oxlint/plugins": "catalog:eslint"
  },
  "devDependencies": {
    "eslint": "catalog:eslint",
    "tsdown": "catalog:build",
    "typescript": "catalog:typescript",
    "vitest": "catalog:test",
    "vue-eslint-parser": "catalog:eslint"
  }
}
