{
  "name": "@nustackjs/lint",
  "type": "module",
  "version": "0.0.1",
  "description": "Zero-config, project-aware ESLint for Nuxt — plug it in and catch Nuxt bugs, not just style.",
  "license": "MIT",
  "repository": "nustackjs/nustack",
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./config": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ],
      "config": [
        "./dist/index.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "pnpm --filter @nustackjs/lint-plugin-vueuse build && nuxt-module-build build && nuxt-module-build prepare && nuxt prepare playground",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "lint": "eslint .",
    "test": "pnpm --filter @nustackjs/lint-plugin-vueuse build && vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "nuxt": ">=3.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@nustackjs/lint-plugin-vueuse": "workspace:*",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/kit": "^4.4.7",
    "@typescript-eslint/utils": "catalog:",
    "defu": "^6.1.7",
    "eslint-flat-config-utils": "^3.2.0",
    "eslint-plugin-better-tailwindcss": "^3.7.10",
    "eslint-plugin-vue": "^10.5.0",
    "unimport": "^6.3.0",
    "vue-eslint-parser": "catalog:"
  },
  "devDependencies": {
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.7",
    "@nuxt/test-utils": "^4.0.3",
    "@types/node": "catalog:",
    "@typescript-eslint/parser": "catalog:",
    "@typescript-eslint/rule-tester": "catalog:",
    "changelogen": "^0.6.2",
    "eslint": "catalog:",
    "nuxt": "^4.4.7",
    "tailwindcss": "^4.0.0",
    "typescript": "catalog:",
    "unbuild": "^3.6.1",
    "vitest": "catalog:",
    "vue-tsc": "^3.3.3"
  }
}
