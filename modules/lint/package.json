{
  "name": "@nustackjs/lint",
  "type": "module",
  "version": "0.4.1",
  "description": "Zero-config, project-aware ESLint (oxlint-ready) for Nuxt — plug it in and catch Nuxt bugs, not just style.",
  "author": "Norbiros <me@norbiros.dev>",
  "license": "MIT",
  "homepage": "https://github.com/Zerya-Dev/nustack/tree/master/modules/lint#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zerya-Dev/nustack.git",
    "directory": "modules/lint"
  },
  "keywords": [
    "eslint",
    "oxlint",
    "nuxt",
    "nustack",
    "lint",
    "vue"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/module.d.mts",
      "import": "./dist/module.mjs"
    },
    "./config": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ],
      "config": [
        "./dist/index.d.mts"
      ]
    }
  },
  "files": [
    "LICENSE",
    "dist"
  ],
  "workspaces": [
    "playground"
  ],
  "scripts": {
    "prepack": "nuxt-module-build build",
    "build": "nuxt-module-build prepare && nuxt-module-build build",
    "dev": "npm run dev:prepare && nuxt dev playground",
    "dev:build": "nuxt build playground",
    "dev:prepare": "pnpm --filter '@nustackjs/lint-plugin-*' build && nuxt-module-build build && nuxt-module-build prepare && nuxt prepare playground",
    "dev:inspector": "npx @eslint/config-inspector --config eslint.config.ts",
    "build:inspector": "npx @eslint/config-inspector build --config eslint.config.ts --out-dir ./.eslint-config-inspector",
    "lint": "eslint .",
    "test": "pnpm --filter '@nustackjs/lint-plugin-*' build && vitest run",
    "test:watch": "vitest watch",
    "test:types": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "peerDependencies": {
    "eslint": ">=9.0.0",
    "nuxt": ">=3.0.0"
  },
  "dependencies": {
    "@antfu/eslint-config": "catalog:eslint",
    "@nustackjs/lint-plugin-nuxt": "workspace:*",
    "@nustackjs/lint-plugin-nuxt-ecosystem": "workspace:*",
    "@nustackjs/lint-plugin-vite": "workspace:*",
    "@nustackjs/lint-plugin-vueuse": "workspace:*",
    "@nuxt/eslint": "catalog:eslint",
    "@nuxt/kit": "catalog:nuxt",
    "@typescript-eslint/utils": "catalog:eslint",
    "defu": "catalog:nuxt",
    "eslint-flat-config-utils": "catalog:eslint",
    "eslint-plugin-better-tailwindcss": "catalog:eslint",
    "eslint-plugin-format": "catalog:eslint",
    "eslint-plugin-vue": "catalog:eslint",
    "exsolve": "catalog:nuxt",
    "mdclint": "catalog:eslint",
    "unimport": "catalog:nuxt",
    "vue-eslint-parser": "catalog:eslint"
  },
  "devDependencies": {
    "@eslint/config-inspector": "catalog:eslint",
    "@nuxt/devtools": "catalog:nuxt",
    "@nuxt/eslint-config": "catalog:eslint",
    "@nuxt/module-builder": "catalog:build",
    "@nuxt/schema": "catalog:nuxt",
    "@nuxt/test-utils": "catalog:nuxt",
    "@types/node": "catalog:typescript",
    "@typescript-eslint/parser": "catalog:eslint",
    "@typescript-eslint/rule-tester": "catalog:eslint",
    "changelogen": "catalog:release",
    "eslint": "catalog:eslint",
    "nuxt": "catalog:nuxt",
    "tailwindcss": "catalog:vue",
    "typescript": "catalog:typescript",
    "unbuild": "catalog:build",
    "vitest": "catalog:test",
    "vue-tsc": "catalog:typescript"
  }
}
